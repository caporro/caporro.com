---
import NotesLoop from "../components/notes-loop.astro";
import PageHeading from "../components/page-heading.astro";
import Layout from "../layouts/main.astro";
---

<Layout title="My Notes">
  <section class="relative z-20 max-w-2xl mx-auto my-12 px-7 lg:px-0">
    <PageHeading
      title="My Notes"
      description="Quick thoughts, insights, and observations from my daily work and learning journey. These are shorter, more informal pieces compared to my full posts."
    />

    <div class="z-50 flex flex-col items-stretch w-full gap-5 my-8">
      <NotesLoop count="999999999" />
    </div>
  </section>
</Layout>

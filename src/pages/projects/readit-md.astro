---
import Button from "../../components/button.astro";
import Layout from "../../layouts/main.astro";

const features = [
  {
    title: "Zero setup, just a link",
    description:
      "Create a readit and share the link. Any AI agent or teammate can consume it instantly — no authentication required.",
  },
  {
    title: "Works with all major AI agents",
    description:
      "Compatible with ChatGPT, Claude, Gemini, Cursor, and any other tool that accepts context via URL.",
  },
  {
    title: "Always up-to-date",
    description:
      "Edit the source once. Every agent or person using the link gets the latest version automatically.",
  },
  {
    title: "Smart organization",
    description:
      "Folders, tags, full-text search powered by PostgreSQL, and dynamic file embedding to keep your knowledge base clean.",
  },
  {
    title: "Template engine",
    description:
      "Variables and templates let you reuse context across different projects without copy-pasting.",
  },
  {
    title: "Version pinning",
    description:
      "Release permalinks let you freeze a specific version of your context for reproducibility.",
  },
];
---

<Layout
  title="readit.md — Portable Context for AI Agents"
  description="readit.md is an open-source tool to create shareable, always-up-to-date context links for AI agents. Works with ChatGPT, Claude, Gemini, and more."
>
  <section class="relative z-20 max-w-4xl mx-auto my-12 px-7 lg:px-0">

    <!-- Back link -->
    <a
      href="/projects"
      class="inline-flex items-center gap-1.5 text-sm text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white transition-colors mb-10"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
      All projects
    </a>

    <!-- Hero -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6 mb-10">
      <div>
        <h1 class="text-4xl font-bold tracking-tight dark:text-neutral-100 mb-3">
          readit<span class="text-indigo-500">|&gt;</span>
        </h1>
        <p class="text-xl text-neutral-600 dark:text-neutral-400 max-w-xl">
          Portable context for AI agents. Dynamic, always-up-to-date context your whole team shares.
        </p>
        <div class="flex flex-wrap gap-3 mt-6">
          <Button text="Open readit.md" link="https://readit.md" />
          <a
            href="https://github.com/claudiocaporro/readit.md"
            target="_blank"
            class="inline-flex items-center gap-2 px-4 py-2 text-sm font-semibold rounded-xl border border-dashed border-neutral-300 dark:border-neutral-600 text-neutral-700 dark:text-neutral-300 hover:border-neutral-500 dark:hover:border-neutral-400 transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
            </svg>
            GitHub
          </a>
        </div>
      </div>
      <div class="flex gap-2 flex-wrap">
        <span class="px-3 py-1 text-xs font-medium rounded-full bg-indigo-50 dark:bg-indigo-950 text-indigo-600 dark:text-indigo-400 border border-indigo-200 dark:border-indigo-800">Open Source</span>
        <span class="px-3 py-1 text-xs font-medium rounded-full bg-green-50 dark:bg-green-950 text-green-600 dark:text-green-400 border border-green-200 dark:border-green-800">Free</span>
      </div>
    </div>

    <!-- Screenshot -->
    <div class="relative mb-14 rounded-2xl overflow-hidden border border-neutral-200 dark:border-neutral-800 shadow-lg">
      <img
        src="/assets/images/projects/readit-md.png"
        alt="readit.md — Portable context for AI agents"
        class="w-full h-auto"
        loading="eager"
      />
    </div>

    <!-- What is it -->
    <div class="mb-12">
      <h2 class="text-2xl font-bold mb-4 dark:text-neutral-100">What is readit.md?</h2>
      <p class="text-base leading-7 text-neutral-600 dark:text-neutral-400 mb-4">
        Every time you start a new chat with an AI agent, you rewrite the same context. Who you are, what the project does, what the conventions are. It's repetitive, error-prone, and doesn't scale to a team.
      </p>
      <p class="text-base leading-7 text-neutral-600 dark:text-neutral-400 mb-4">
        readit.md solves this: you write your context once as a markdown document, publish it as a shareable link, and paste that link into any AI tool. The agent reads it, understands your world, and you skip the repetition.
      </p>
      <p class="text-base leading-7 text-neutral-600 dark:text-neutral-400">
        Works with ChatGPT, Claude, Gemini, Cursor, and any other tool that accepts a URL as context. Open source and free.
      </p>
    </div>

    <!-- Features -->
    <h2 class="text-2xl font-bold mb-6 dark:text-neutral-100">Features</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-14">
      {
        features.map((feature) => (
          <div class="p-5 border border-dashed border-neutral-200 dark:border-neutral-700 rounded-xl">
            <h3 class="font-semibold text-base mb-1.5 dark:text-neutral-100">{feature.title}</h3>
            <p class="text-sm leading-6 text-neutral-600 dark:text-neutral-400">{feature.description}</p>
          </div>
        ))
      }
    </div>

    <!-- CTA -->
    <div class="p-8 bg-neutral-50 dark:bg-neutral-900 border border-dashed border-neutral-200 dark:border-neutral-700 rounded-2xl text-center">
      <h2 class="text-xl font-bold mb-2 dark:text-neutral-100">Try it now</h2>
      <p class="text-sm text-neutral-600 dark:text-neutral-400 mb-5">
        Free, open source, zero setup required.
      </p>
      <Button text="Go to readit.md" link="https://readit.md" />
    </div>

  </section>
</Layout>
